# SerpAPI key from https://serpapi.com/manage-api-key (cash flight search)
# Keep this on the backend only — never put it in the frontend or GitHub Pages build.
SERPAPI_API_KEY=your_api_key_here

# Seats.aero Pro API key from https://seats.aero/ → Settings → API (award/points search)
SEATS_AERO_API_KEY=your_seats_aero_api_key_here

# Currency code for flight prices (USD, EUR, GBP, etc.)
SERPAPI_CURRENCY=USD

# Google Flights localization (country and language)
SERPAPI_GL=us
SERPAPI_HL=en

# Comma-separated browser origins allowed to call the API (CORS + origin check).
# Add your GitHub Pages URL when deploying, e.g. https://yourname.github.io
# Both localhost and 127.0.0.1 are accepted for each listed port.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional shared secret checked via X-App-Key header. Slows casual scraping but is
# visible in the static frontend bundle — use together with rate limits, not alone.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_API_KEY=

# Per-IP rate limit for /api/* (except /api/health)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Frontend build vars (set in .env.local or GitHub Actions, not committed):
# VITE_API_BASE_URL=https://your-backend.example.com
# VITE_APP_API_KEY=same value as APP_API_KEY when using the app key gate
#
# Firebase (Authentication + Firestore) — put in .env.local (frontend only, not read by Python)
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
#
# Contact form (optional — for email notifications via Firebase Trigger Email extension)
# Messages are always saved to Firestore contactMessages (view in Firebase Console).
# To also get an email inbox notification, install "Trigger Email from Firestore"
# in Firebase Console and set your address here:
# VITE_CONTACT_TO_EMAIL=you@example.com
#
# Tracked deal price alerts (backend only)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT_PATH=path/to/serviceAccountKey.json
# ALERTS_CRON_SECRET=generate_a_long_random_secret
# APP_BASE_URL=https://your-production-site.example.com
#
# Run daily checks via cron or HTTP POST:
#   python scripts/run_tracked_deal_alerts.py
#   curl -X POST -H "X-Alerts-Cron-Secret: $ALERTS_CRON_SECRET" https://your-api/api/internal/check-tracked-deals
